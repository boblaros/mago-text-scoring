{
  "seed": 42,
  "data_dir": "data",
  "output_dir": "outputs",
  "model_dir": "models",
  "log_dir": "logs",
  "task": "complexity-classification",
  "text_col": "text",
  "label_col": "label",
  "num_labels": 3,
  "encoded_label_col": "label_enc",
  "train_pool_key": "train_pool",
  "train_pool_datasets": [
    "uk_key_stage",
    "asap2"
  ],
  "external_eval_dataset_keys": [
    "one_stop",
    "commonlit",
    "cerf",
    "cambridge",
    "asap_aes"
  ],
  "split_artifact_path": "data/complexity_splits.pkl",
  "experiment_dataset_slug": "complexity",
  "run_data_prep": false,
  "run_transformer_eval": true,
  "dl_train_mode": false,
  "test_size": 0.15,
  "val_size": 0.15,
  "use_cv": true,
  "cv_folds": 5,
  "tfidf_word_ngrams": [
    1,
    2
  ],
  "use_char_ngrams": true,
  "class_weight": "balanced",
  "embedding_model": "fasttext-wiki-news-subwords-300",
  "embedding_dim": 300,
  "vocab_size": 50000,
  "max_seq_len": 256,
  "pad_token": "<PAD>",
  "unk_token": "<UNK>",
  "dl_batch_size": 64,
  "dl_epochs": 20,
  "dl_lr": 0.001,
  "dl_patience": 3,
  "dropout": 0.3,
  "cnn_num_filters": 128,
  "cnn_kernel_sizes": [
    2,
    3,
    4
  ],
  "lstm_hidden_dim": 128,
  "lstm_num_layers": 2,
  "trf_model": "distilbert-base-uncased",
  "max_len": 256,
  "batch_size": 8,
  "epochs": 3,
  "lr": 2e-05,
  "device": "mps",
  "output_paths": {
    "eda": "outputs/eda",
    "metrics": "outputs/metrics",
    "runs": "outputs/runs",
    "plots_confusion": "outputs/plots/confusion_matrices",
    "plots_comparison": "outputs/plots/comparisons",
    "plots_learning": "outputs/plots/learning_curves",
    "plots_history": "outputs/plots/histories"
  }
}