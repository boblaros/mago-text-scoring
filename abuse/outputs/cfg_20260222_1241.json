{
  "seed": 42,
  "data_dir": "data",
  "output_dir": "outputs",
  "model_dir": "models",
  "log_dir": "logs",
  "task": "abuse_detection",
  "text_col": "text",
  "label_col": "target",
  "num_labels": 3,
  "test_size": 0.15,
